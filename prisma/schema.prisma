generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  username String @unique
  password String

  avatar String?
  bio String?

  isVerified Boolean @default(false)
  isEmailVerified Boolean @default(false)
  isTotpEnabled  Boolean @default(false)
  totpSecret  String?

  isDeactivated Boolean   @default(false)
  deactivatedAt DateTime?

  tokens Token[]
  socialLinks SocialLink[]
  stream Stream?
  chatMessages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Token {
  id        String    @id @default(uuid())
  token     String    @unique
  type      TokenType
  expiresIn DateTime

  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tokens")
}

model SocialLink {
  id        String   @id @default(uuid())
  title     String
  url       String
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("social_links")
}

model Stream {
  id           String  @id @default(uuid())
  title        String
  thumbnailUrl String?

  ingressId    String?       @unique
  serverUrl    String?
  streamKey    String?

  isLive       Boolean       @default(false)

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @unique

  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String?

  chatMessages ChatMessage[]

  isChatEnabled              Boolean @default(true)
  isChatFollowersOnly        Boolean @default(false)
  isChatPremiumFollowersOnly Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("streams")
}

model Category {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  description  String
  thumbnailUrl String
  streams      Stream[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("category")
}

model ChatMessage {
  id   String @id @default(uuid())
  text String

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  stream   Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)
  streamId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_messages")
}


enum TokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
  DEACTIVATE_ACCOUNT
  TELEGRAM_AUTH

  @@map("TOKEN_TYPES")
}
